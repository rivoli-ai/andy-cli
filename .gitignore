## A streamlined .gitignore for modern .NET projects
## including temporary files, build results, and
## files generated by popular .NET tools. If you are
## developing with Visual Studio, the VS .gitignore
## https://github.com/github/gitignore/blob/main/VisualStudio.gitignore
## has more thorough IDE-specific entries.
##
## Get latest from https://github.com/github/gitignore/blob/main/Dotnet.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg

# Others
~$*
*~
CodeCoverage/

# Test coverage and results
coverage/
coveragereport/
coverage-results/
coverage-results-*/
coverage-report/
coverage-report-*/
test-results/
test-results-*/

# macOS
.DS_Store
**/.DS_Store

# Rider/IDE per-user settings
*.DotSettings.user

# JetBrains IDEs
.idea/

# Benchmarks (removed from repo)
benchmarks/Andy.Tui.Benchmarks/

# Container build artifacts
container/bin-safe/
container/bin-isolated/
container/rootfs/
container/rootfs-safe/

# MSBuild Binary and Structured Log
*.binlog

# MSTest test Results
[Tt]est-[Rr]esult*/
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Release artifacts
# Published build output (self-contained binaries, debug symbols, SBOMs, checksums)
# must never be tracked. Regenerate locally via scripts/build-release.sh (see RELEASE.md);
# release artifacts are produced only in CI from a clean tagged revision.
release-artifacts/
publish/
**/publish/
*.tar.gz
*.zip
*.sha256
*.pdb
sbom*.json
SHA256SUMS.txt

# Claude Code local session/worktree data
.claude/

# Andy local permission layer (the project layer may be committed deliberately;
# the local layer and runtime data under ./.andy are developer-specific)
.andy/permissions.local.json

# Local secrets and environment files (API keys live in the environment, never in git)
.env
.env.*
!.env.example
*.local.json
