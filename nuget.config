<?xml version="1.0" encoding="utf-8"?>
<!-- Pin package sources for this repo to nuget.org only, overriding any user-level
     configuration. Local nupkgs feeds in a developer's user config otherwise leak
     locally built package copies into packages.lock.json content hashes, producing
     locks no clean machine (including CI) can validate (NU1403). All referenced
     package versions are published to nuget.org. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
